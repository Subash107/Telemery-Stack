# Production profile
ENV=prod
# Explicit API_URL overrides the auto Docker/local host selection.
API_URL=https://secure-test.six-swiss-exchange.com
API_HEALTH_PATH=/health
API_LOGIN_PATH=/login
API_UPLOAD_PATH=/upload
API_TIMEOUT_SECONDS=15

# Set these locally or through CI secrets.
API_USERNAME=replace-me
API_PASSWORD=replace-me

TARGETS_FILE=targets/programs.txt
DB_PATH=database/findings.db
RESULTS_DIR=results
ARTIFACTS_DIR=artifacts
MOCK_STORAGE_DIR=mock_api_uploads
ENABLE_PACKAGING=true
ENABLE_API_SYNC=false
