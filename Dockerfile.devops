FROM python:3.12-slim

COPY services/mock_api/requirements.txt /tmp/mock-api-requirements.txt

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash curl ca-certificates \
    && pip install --no-cache-dir -r /tmp/mock-api-requirements.txt \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY . /workspace

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
